{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (Student, Admin, Counselor, etc.)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": {
          "type": "string",
          "enum": ["STUDENT", "COUNSELOR", "ADMIN", "TRAINEE", "COLLEGE_PARTNER", "ASSOCIATE_PARTNER"],
          "description": "User role"
        },
        "mobile": { "type": "string", "description": "Mobile number" },
        "whatsapp": { "type": "string", "description": "WhatsApp number" },
        "crmAccess": { "type": "boolean", "description": "Grants access to CRM features" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Student inquiry about a course or college",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "studentId": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "course": { "type": "string" },
        "query": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "ANSWERED"] },
        "notes": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string" }
      },
      "required": ["studentName", "email", "query"]
    },
    "University": {
      "title": "University",
      "description": "A university entity",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "modes": { "type": "array", "items": { "type": "string", "enum": ["Regular", "Online", "Distance"] } },
        "image": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "description": { "type": "string" },
        "courses": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name"]
    },
    "Course": {
      "title": "Course",
      "description": "A course offered by a university",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Diploma", "UG", "PG"] },
        "modes": { "type": "array", "items": { "type": "string", "enum": ["Regular", "Online", "Distance"] } },
        "description": { "type": "string" },
        "universityId": { "type": "string" }
      },
      "required": ["name", "type"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Users collection keyed by Auth UID"
    },
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "All student inquiries"
    },
    "universities/{universityId}": {
      "schema": "University",
      "description": "List of universities"
    },
    "courses/{courseId}": {
      "schema": "Course",
      "description": "List of courses"
    }
  }
}
