{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (Student, Admin, Counselor, etc.)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": {
          "type": "string",
          "enum": ["STUDENT", "COUNSELOR", "ADMIN", "TRAINEE", "COLLEGE_PARTNER", "ASSOCIATE_PARTNER"],
          "description": "User role"
        },
        "mobile": { "type": "string", "description": "Mobile number" },
        "whatsapp": { "type": "string", "description": "WhatsApp number" },
        "crmAccess": { "type": "boolean", "description": "Grants access to CRM features" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Student inquiry about a course or college",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "studentId": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "course": { "type": "string" },
        "query": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "ANSWERED"] },
        "notes": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string" }
      },
      "required": ["studentName", "email", "query"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Users collection keyed by Auth UID"
    },
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "All student inquiries"
    }
  }
}
